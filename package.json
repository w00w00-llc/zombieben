{
  "name": "zombieben",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "CLI tool for zombieben workflows",
  "bin": {
    "zombieben": "./dist/index.js"
  },
  "files": [
    "dist",
    "scaffold"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
